{
	"compilerOptions": {
		"module": "commonjs",
		"target": "es2020",
		"strict": true,
		"noUnusedParameters": false,
		"noUnusedLocals": true,
		"outDir": "out",
		"sourceMap": true,
		"declaration": true,
		"skipLibCheck": true,
		"baseUrl": ".",
		"paths": {
			"playwright-core/types/*": [
				"../../node_modules/playwright/node_modules/playwright-core/types/*"
			]
		},
		"lib": [
			"esnext", // for #201187
			"dom"
		]
	},
	"exclude": [
		"node_modules",
		"out",
		"tools"
	]
}
